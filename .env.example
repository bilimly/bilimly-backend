# ==============================
# BILIMLY BACKEND - ENV CONFIG
# ==============================

# Server
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://bilimly.kg

# Database (Railway PostgreSQL - fill after deploy)
DATABASE_URL=postgresql://user:password@host:5432/bilimly

# JWT Auth
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Anthropic Claude API (for AI agents)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Mbank QR Payment
MBANK_MERCHANT_ID=your_mbank_merchant_id
MBANK_API_KEY=your_mbank_api_key
MBANK_API_URL=https://api.mbank.kg/v1

# WhatsApp (360dialog)
WHATSAPP_API_KEY=your_360dialog_api_key
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# Instagram (Meta)
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_id
META_VERIFY_TOKEN=bilimly_webhook_verify_2024

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@bilimly.kg

# Video Lessons (Daily.co - free plan available at daily.co)
# If not set, falls back to free Jitsi Meet automatically
DAILY_API_KEY=your_daily_co_api_key

# Admin
ADMIN_EMAIL=admin@bilimly.kg
ADMIN_PASSWORD=change_this_immediately
